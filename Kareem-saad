-- [[ SAADHUB - FPS BOOST + WHITE BOMB (PROTECT FACES) ]] --

local function startSaadHubSafe()
    -- 1. حماية الوجوه والملامح (تجاهل أي شيء يخص اللاعبين)
    local function isPlayerPart(obj)
        return obj:IsDescendantOf(game.Players) or obj:FindFirstAncestorOfClass("Model"):FindFirstChild("Humanoid")
    end

    local function cleanObject(v)
        -- شرط ذهبي: إذا كان الجزء يخص لاعب، اتركه ولا تلمسه
        if isPlayerPart(v) then return end

        -- 2. تحويل القنابل والماب (بدون لمس وجوه اللاعبين)
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
            -- تحويل القنبلة السوداء إلى بيضاء
            if v.Color.r < 0.2 and v.Color.g < 0.2 and v.Color.b < 0.2 then
                v.Color = Color3.fromRGB(255, 255, 255)
            end
        -- حذف الصور (Textures) للماب فقط وليس للاعبين
        elseif v:IsA("Decal") or v:IsA("Texture") then
            -- التأكد أن الملصق ليس "وجهاً" (Face) للاعب
            if v.Name ~= "face" and not v.Parent:IsA("Accessory") then
                v:Destroy()
            end
        -- إخفاء تعليق الانفجارات والدخان
        elseif v:IsA("ParticleEmitter") or v:IsA("Explosion") then
            if v:IsA("Explosion") then v.Visible = false end
            if v:IsA("ParticleEmitter") then v.Enabled = false end
        end
    end

    -- تنظيف الماب الحالي
    for _, v in pairs(game.Workspace:GetDescendants()) do
        pcall(function() cleanObject(v) end)
    end

    -- تنظيف أي قنابل أو قطع ماب جديدة تظهر
    game.Workspace.DescendantAdded:Connect(function(v)
        pcall(function() cleanObject(v) end)
    end)
end

-- تشغيل السكربت المطور
pcall(startSaadHubSafe)

-- إشعار SAADHUB
game:GetService("StarterGui"):SetCore("SendNotification", {
    Title = "SAADHUB V2",
    Text = "تخفيف اللاق + حماية الوجوه ✅👤",
    Duration = 5
})
