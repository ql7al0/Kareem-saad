-- [[ SAADHUB ELITE - ZERO LAG & MAXIMUM PERFORMANCE ]] --

local UserSettings = settings()
local RenderSettings = UserSettings.Network
local PhysicsSettings = settings().Physics

-- 1. تقليل جودة الرندر البرمجية (Lowering Internal Quality)
UserSettings.Rendering.QualityLevel = Enum.QualityLevel.Level01
settings().Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level01

-- 2. تحسين استهلاك المعالج (CPU Optimization)
setfpscap(999) -- فتح الفريمات لأقصى حد

local function CleanWorld(v)
    -- إزالة الظلال والإنعكاسات من كل القطع
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.Material = Enum.Material.SmoothPlastic
        v.Reflectance = 0
        v.CastShadow = false
    end
    
    -- حذف الصور المتكررة (Textures) التي تستهلك الرام
    if v:IsA("Texture") or (v:IsA("Decal") and v.Name ~= "face") then
        v:Destroy()
    end

    -- إيقاف أي جزيئات متحركة (Particles)
    if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Sparkles") then
        v.Enabled = false
        v:Destroy()
    end

    -- حذف تأثيرات الضوء المجهدة
    if v:IsA("PointLight") or v:IsA("SpotLight") or v:IsA("SurfaceLight") then
        v.Enabled = false
        v.Shadows = false
    end
end

-- تنظيف الماب الحالي
for _, v in pairs(game:GetDescendants()) do
    pcall(CleanWorld, v)
end

-- مراقبة العناصر الجديدة (مثل القنابل أو الانفجارات)
game.DescendantAdded:Connect(function(v)
    pcall(CleanWorld, v)
end)

-- 3. تصفير إعدادات الإضاءة العالمية (Lighting Override)
local Lighting = game:GetService("Lighting")
Lighting.GlobalShadows = false
Lighting.FogEnd = 100000
Lighting.Brightness = 2
Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)

-- حذف الفلاتر (Blur, Bloom, ColorCorrection)
for _, effect in pairs(Lighting:GetChildren()) do
    if not effect:IsA("Sky") then
        effect:Destroy()
    end
end

-- إشعار التشغيل النهائي
game:GetService("StarterGui"):SetCore("SendNotification", {
    Title = "SAADHUB ELITE",
    Text = "Extreme FPS Boost Enabled! 🚀",
    Duration = 5
})
