-- [[ ULTIMATE LAG KILLER & FPS BOOST - BY GEMINI ]] --

local settings = {
    DestroyTextures = true,
    DestroyDecals = true,
    DestroyParticles = true,
    LowLighting = true,
    SmoothPlasticAll = true
}

local function boost(v)
    -- 1. تعطيل الانفجارات تماماً
    if v:IsA("Explosion") then
        v.BlastRadius = 0
        v.BlastPressure = 0
        v.Visible = false
        v:Destroy()
    end

    -- 2. تحويل الخامات إلى بلاستيك ناعم (أخف شيء على الكرت)
    if v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("Part") then
        v.Material = Enum.Material.SmoothPlastic
        v.CastShadow = false
        v.Reflectance = 0
    end

    -- 3. حذف الصور والملصقات (Decals) لتقليل استهلاك الذاكرة
    if (v:IsA("Decal") or v:IsA("Texture")) and v.Name ~= "face" then
        v:Destroy()
    end

    -- 4. حذف التأثيرات المتحركة (نار، دخان، جزيئات)
    if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") then
        v.Enabled = false
        task.wait()
        v:Destroy()
    end
    
    -- 5. تقليل جودة الشبكات (Meshes)
    if v:IsA("MeshPart") then
        v.RenderFidelity = Enum.RenderFidelity.Performance
    end
end

-- تطبيق الإعدادات على الماب بالكامل
for _, v in pairs(game.Workspace:GetDescendants()) do
    pcall(boost, v)
end

-- مراقبة أي شيء جديد يظهر وحذفه فوراً
game.Workspace.DescendantAdded:Connect(function(v)
    pcall(boost, v)
end)

-- 6. تعديل إعدادات الإضاءة (أكبر مسبب للاق)
local lighting = game:GetService("Lighting")
lighting.GlobalShadows = false
lighting.FogEnd = 9e9
lighting.Brightness = 1

for _, effect in pairs(lighting:GetChildren()) do
    if effect:IsA("PostEffect") or effect:IsA("BloomEffect") or effect:IsA("BlurEffect") or effect:IsA("SunRaysEffect") then
        effect.Enabled = false
    end
end

-- إشعار بنجاح العملية
game:GetService("StarterGui"):SetCore("SendNotification", {
    Title = "FPS BOOST ACTIVE",
    Text = "All Lag Sources Cleared! 🚀",
    Duration = 5
})
